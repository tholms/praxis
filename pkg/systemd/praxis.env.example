#
# Praxis service configuration.
# Edited by `praxisctl set rabbitmq-url <url>`, but you can edit by hand too.
# Restart the services after changes:
#   praxisctl restart && praxisctl webserver restart
#

PRAXIS_RABBITMQ_URL=amqp://praxis:praxis@localhost:5672
PRAXIS_DATABASE_URL=/var/lib/praxis/praxis.db
PRAXIS_NODES_DIR=/usr/local/share/praxis/nodes
