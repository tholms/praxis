[Unit]
Description=Praxis Service
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/praxis_service
EnvironmentFile=-/etc/praxis/env
User=praxis
Group=praxis
WorkingDirectory=/var/lib/praxis
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
